# Larry Agent Environment Variables
# ===================================
# Copy this to .env and fill in your values:  cp .env.example .env

# HuggingFace Token (for downloading gated models like BAAI reranker)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=
HUGGINGFACE_TOKEN=

# Brave Search (for /search_web command)
# Get key at: https://brave.com/search/api/
BRAVE_API_KEY=

# GitHub (for GitHub MCP server)
# Create PAT at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Telegram Bot (for remote queries and security alerts)
# Create bot via @BotFather on Telegram, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOW_ALL=false

# Ollama (should match your systemd config)
OLLAMA_HOST=http://localhost:11434

# OpenRouter API (optional cloud model fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# RAG Backend (chroma is the only supported backend currently)
RAG_BACKEND=chroma

# Disable all telemetry
ANONYMIZED_TELEMETRY=False
CHROMA_TELEMETRY=False
POSTHOG_DISABLED=1
DO_NOT_TRACK=1
TF_ENABLE_ONEDNN_OPTS=0
TF_CPP_MIN_LOG_LEVEL=2
